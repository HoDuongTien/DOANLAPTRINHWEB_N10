@page
@model LoginModel

@{
    ViewData["Title"] = "Log in";
}

<div class="auth-split-page">
    <div class="auth-left">
        <div class="auth-form-box">
            <h1>Đăng nhập</h1>
            <p class="auth-subtitle">Chào mừng bạn quay lại hệ thống quản lý nhân sự</p>

            <form id="account" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-3">
                    <label asp-for="Input.Email" class="form-label">Email</label>
                    <input asp-for="Input.Email" class="form-control auth-input" autocomplete="username" />
                    <span asp-validation-for="Input.Email" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Input.Password" class="form-label">Mật khẩu</label>
                    <input asp-for="Input.Password" class="form-control auth-input" autocomplete="current-password" />
                    <span asp-validation-for="Input.Password" class="text-danger"></span>
                </div>

                <div class="form-check mb-3">
                    <input class="form-check-input" asp-for="Input.RememberMe" />
                    <label class="form-check-label" asp-for="Input.RememberMe">
                        Ghi nhớ đăng nhập
                    </label>
                </div>

                <button id="login-submit" type="submit" class="btn auth-main-btn">Đăng nhập</button>

                <div class="auth-links">
                    <a asp-page="./ForgotPassword">Quên mật khẩu?</a>
                    <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl">Đăng ký tài khoản mới</a>
                </div>
            </form>
        </div>
    </div>

    <div class="auth-right">
        <div class="auth-info-box">
            <div class="auth-badge">4 ANH TÀI</div>
            <h2>Nền tảng quản lý nhân sự hiện đại, trực quan và dễ sử dụng</h2>
            <p>
                Tối ưu quy trình quản lý nhân sự với giao diện thân thiện,
                giúp doanh nghiệp theo dõi nhân viên, phòng ban, chấm công,
                nghỉ phép và bảng lương hiệu quả hơn.
            </p>
            <ul class="auth-feature-list">
                <li>Giao diện rõ ràng, dễ thao tác</li>
                <li>Hỗ trợ quản lý tập trung</li>
                <li>Tiết kiệm thời gian xử lý nghiệp vụ</li>
                <li>Phù hợp cho doanh nghiệp hiện đại</li>
            </ul>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

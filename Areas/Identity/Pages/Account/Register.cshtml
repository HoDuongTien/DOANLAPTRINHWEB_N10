@page
@model RegisterModel
@{
    ViewData["Title"] = "Register";
}
<div class="auth-split-page">
    <div class="auth-left">
        <div class="auth-form-box">
            <h1>Đăng ký</h1>
            <p class="auth-subtitle">Tạo tài khoản mới để sử dụng hệ thống</p>

            <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-3">
                    <label asp-for="Input.Email" class="form-label">Email</label>
                    <input asp-for="Input.Email" class="form-control auth-input" autocomplete="username" />
                    <span asp-validation-for="Input.Email" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Input.Password" class="form-label">Mật khẩu</label>
                    <input asp-for="Input.Password" class="form-control auth-input" autocomplete="new-password" />
                    <span asp-validation-for="Input.Password" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Input.ConfirmPassword" class="form-label">Xác nhận mật khẩu</label>
                    <input asp-for="Input.ConfirmPassword" class="form-control auth-input" autocomplete="new-password" />
                    <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
                </div>

                <button id="registerSubmit" type="submit" class="btn auth-main-btn">Đăng ký</button>

                <div class="auth-switch-link">
                    Đã có tài khoản?
                    <a asp-page="./Login" asp-route-returnUrl="@Model.ReturnUrl">Đăng nhập</a>
                </div>
            </form>
        </div>
    </div>

    <div class="auth-right">
        <div class="auth-info-box">
            <div class="auth-badge">HR SYSTEM</div>
            <h2>Quản lý nhân sự thông minh cho doanh nghiệp hiện đại</h2>
            <p>
                Hệ thống hỗ trợ quản lý nhân viên, phòng ban, chấm công,
                nghỉ phép và bảng lương trên một nền tảng thống nhất,
                dễ sử dụng và trực quan.
            </p>

            <ul class="auth-feature-list">
                <li>Quản lý hồ sơ nhân viên nhanh chóng</li>
                <li>Theo dõi chấm công và ca làm việc</li>
                <li>Xử lý nghỉ phép minh bạch</li>
                <li>Hỗ trợ quản lý lương hiệu quả</li>
            </ul>
        </div>
    </div>
</div>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

@model WebQLNhanSu.Models.NhanVien

@{
    ViewData["Title"] = "Chi tiết nhân viên";
}

<h2 class="mb-3">Chi tiết nhân viên</h2>

<div class="card">
    <div class="card-body">

        <dl class="row">
            <dt class="col-sm-4">Mã nhân viên</dt>
            <dd class="col-sm-8">@Model.MaNhanVien</dd>

            <dt class="col-sm-4">Tên nhân viên</dt>
            <dd class="col-sm-8">@Model.TenNhanVien</dd>

            <dt class="col-sm-4">Ngày sinh</dt>
            <dd class="col-sm-8">@Model.NgaySinh?.ToString("dd/MM/yyyy")</dd>

            <dt class="col-sm-4">Giới tính</dt>
            <dd class="col-sm-8">@Model.GioiTinh</dd>

            <dt class="col-sm-4">Số điện thoại</dt>
            <dd class="col-sm-8">@Model.SoDienThoai</dd>

            <dt class="col-sm-4">Địa chỉ</dt>
            <dd class="col-sm-8">@Model.DiaChi</dd>

            <dt class="col-sm-4">Phòng ban</dt>
            <dd class="col-sm-8">@Model.PhongBan?.TenPhongBan</dd>

            <dt class="col-sm-4">Chức vụ</dt>
            <dd class="col-sm-8">@Model.ChucVu?.TenChucVu</dd>

            <dt class="col-sm-4">Trình độ</dt>
            <dd class="col-sm-8">@Model.TrinhDo?.TenTrinhDo</dd>
        </dl>

    </div>
</div>

<div class="mt-3">
    <a asp-action="Edit" asp-route-id="@Model.MaNhanVien" class="btn btn-primary">
        <i class="fa fa-edit"></i> Sửa
    </a>
    <a asp-action="Delete" asp-route-id="@Model.MaNhanVien" class="btn btn-danger">
        <i class="fa fa-trash"></i> Xóa
    </a>
    <a asp-action="Index" class="btn btn-secondary">
        <i class="fa fa-arrow-left"></i> Quay lại
    </a>
</div>
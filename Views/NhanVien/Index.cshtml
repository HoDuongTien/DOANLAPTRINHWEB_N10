@model IEnumerable<WebQLNhanSu.Models.NhanVien>

<h2 class="mb-3">Danh sách nhân viên</h2>

<p>
    <a asp-action="Create" class="btn btn-success">+ Thêm nhân viên</a>
</p>

<form method="get" asp-action="Index" class="row g-2 mb-3">
    <div class="col-md-5">
        <input type="text"
               name="search"
               class="form-control"
               placeholder="Nhập tên, số điện thoại, địa chỉ, phòng ban..."
               value="@ViewBag.Search" />
    </div>
    <div class="col-md-auto">
        <button type="submit" class="btn btn-primary">
            <i class="bi bi-search"></i> Tìm kiếm
        </button>
        <a asp-action="Index" class="btn btn-secondary">
            <i class="bi bi-arrow-clockwise"></i> Làm mới
        </a>
    </div>
</form>

<div class="table-responsive">
    <table class="table table-bordered table-striped table-hover align-middle">
        <thead class="table-dark">
            <tr>
                <th>Mã</th>
                <th>Tên</th>
                <th>Ngày sinh</th>
                <th>Điện thoại</th>
                <th>Địa chỉ</th>
                <th>Phòng ban</th>
                <th>Chức vụ</th>
                <th class="text-center" style="min-width:260px;">Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.MaNhanVien</td>
                    <td>@item.TenNhanVien</td>
                    <td>@item.NgaySinh?.ToString("dd/MM/yyyy")</td>
                    <td>@item.SoDienThoai</td>
                    <td>@item.DiaChi</td>
                    <td>@item.PhongBan?.TenPhongBan</td>
                    <td>@item.ChucVu?.TenChucVu</td>
                    <td>
                        <div class="action-buttons">
                            <a asp-action="Edit" asp-route-id="@item.MaNhanVien" class="btn btn-edit">
                                <i class="bi bi-pencil me-1"></i> Sửa
                            </a>
                            <a asp-action="Delete" asp-route-id="@item.MaNhanVien" class="btn btn-delete">
                                <i class="bi bi-trash me-1"></i> Xóa
                            </a>
                            <a asp-action="Details" asp-route-id="@item.MaNhanVien" class="btn btn-info">
                                <i class="bi bi-info-circle me-1"></i> Chi tiết
                            </a>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<div class="mt-3">
    <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
</div>
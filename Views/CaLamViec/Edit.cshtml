@model WebQLNhanSu.Models.CaLamViec

<h2>Sửa ca làm việc</h2>

<form asp-action="Edit">
    <input type="hidden" asp-for="MaCa" />
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="mb-3">
        <label asp-for="TenCa" class="form-label">Tên ca</label>
        <input asp-for="TenCa" class="form-control" />
        <span asp-validation-for="TenCa" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="GioBatDau" class="form-label">Giờ bắt đầu</label>
        <input asp-for="GioBatDau" type="time" class="form-control" />
        <span asp-validation-for="GioBatDau" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="GioKetThuc" class="form-label">Giờ kết thúc</label>
        <input asp-for="GioKetThuc" type="time" class="form-control" />
        <span asp-validation-for="GioKetThuc" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Lưu</button>
    <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
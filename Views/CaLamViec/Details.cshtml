@model WebQLNhanSu.Models.CaLamViec

@{
    ViewData["Title"] = "Chi tiết ca làm việc";
}

<div class="crud-page">
    <div class="card card-modern p-4 p-md-5">
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4">
            <div>
                <h2 class="section-title mb-1">Chi tiết ca làm việc</h2>
                <p class="section-subtitle mb-0">Xem thông tin chi tiết của ca làm việc</p>
            </div>
            <span class="badge-soft mt-3 mt-md-0">Danh mục</span>
        </div>

        <div class="row g-4">
            <div class="col-md-4">
                <label class="form-label">Mã ca</label>
                <div class="detail-box">@Model.MaCa</div>
            </div>

            <div class="col-md-4">
                <label class="form-label">Tên ca</label>
                <div class="detail-box">@Model.TenCa</div>
            </div>

            <div class="col-md-2">
                <label class="form-label">Giờ bắt đầu</label>
                <div class="detail-box">@Model.GioBatDau.ToString(@"hh\:mm")</div>
            </div>

            <div class="col-md-2">
                <label class="form-label">Giờ kết thúc</label>
                <div class="detail-box">@Model.GioKetThuc.ToString(@"hh\:mm")</div>
            </div>
        </div>

        <div class="page-actions">
            <a asp-action="Edit" asp-route-id="@Model.MaCa" class="btn btn-warning">Sửa</a>
            <a asp-action="Index" class="btn btn-outline-secondary">Quay lại</a>
        </div>
    </div>
</div>
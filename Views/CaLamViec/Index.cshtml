@model IEnumerable<WebQLNhanSu.Models.CaLamViec>

<h2>Danh sách ca làm việc</h2>

<p>
    <a asp-action="Create" class="btn btn-primary">Thêm mới</a>
</p>

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Mã ca</th>
            <th>Tên ca</th>
            <th>Giờ bắt đầu</th>
            <th>Giờ kết thúc</th>
            <th width="220">Thao tác</th>
        </tr>
    </thead>
    <tbody>
    @foreach (var item in Model)
    {
        <tr>
            <td>@item.MaCa</td>
            <td>@item.TenCa</td>
            <td>@item.GioBatDau.ToString(@"hh\:mm")</td>
            <td>@item.GioKetThuc.ToString(@"hh\:mm")</td>
            <td>
                <a asp-action="Details" asp-route-id="@item.MaCa" class="btn btn-info btn-sm">Chi tiết</a>
                <a asp-action="Edit" asp-route-id="@item.MaCa" class="btn btn-warning btn-sm">Sửa</a>
                <a asp-action="Delete" asp-route-id="@item.MaCa" class="btn btn-danger btn-sm">Xóa</a>
            </td>
        </tr>
    }
    </tbody>
</table>
@model IEnumerable<WebQLNhanSu.Models.CaLamViec>

<h2>Danh sách ca làm việc</h2>

<p>
    <a asp-action="Create" class="btn btn-primary">Thêm mới</a>
</p>

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Mã ca</th>
            <th>Tên ca</th>
            <th>Giờ bắt đầu</th>
            <th>Giờ kết thúc</th>
            <th width="220">Thao tác</th>
        </tr>
    </thead>
    <tbody>
    @foreach (var item in Model)
    {
        <tr>
            <td>@item.MaCa</td>
            <td>@item.TenCa</td>
            <td>@item.GioBatDau.ToString(@"hh\:mm")</td>
            <td>@item.GioKetThuc.ToString(@"hh\:mm")</td>
            <td>
                <div class=action-buttons>
                    <a asp-action="Edit" asp-route-id="@item.MaCa" class="btn btn-edit">
                        <i class="bi bi-pencil me-1"></i> Sửa
                    </a>
                    <a asp-action="Delete" asp-route-id="@item.MaCa" class="btn btn-delete">
                        <i class="bi bi-trash me-1"></i> Xóa </a>
                    <a asp-action="Details" asp-route-id="@item.MaCa" class="btn btn-info">
                        <i class="bi bi-info-circle me-1"></i> Chi tiết </a>
                </div>
            </td>
        </tr>
    }
    </tbody>
</table>
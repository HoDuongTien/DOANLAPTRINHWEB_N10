@model WebQLNhanSu.Models.TrinhDo

@{
    ViewData["Title"] = "Chi tiết trình độ";
}

<div class="crud-page">
    <div class="card card-modern p-4 p-md-5">
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4">
            <div>
                <h2 class="section-title mb-1">Chi tiết trình độ</h2>
                <p class="section-subtitle mb-0">Xem thông tin chi tiết của trình độ</p>
            </div>
            <span class="badge-soft mt-3 mt-md-0">Danh mục</span>
        </div>

        <div class="row g-4">
            <div class="col-md-6">
                <label class="form-label">Mã trình độ</label>
                <div class="detail-box">@Model.MaTrinhDo</div>
            </div>

            <div class="col-md-6">
                <label class="form-label">Tên trình độ</label>
                <div class="detail-box">@Model.TenTrinhDo</div>
            </div>
        </div>

        <div class="page-actions">
            <a asp-action="Edit" asp-route-id="@Model.MaTrinhDo" class="btn btn-warning">Sửa</a>
            <a asp-action="Index" class="btn btn-outline-secondary">Quay lại</a>
        </div>
    </div>
</div>
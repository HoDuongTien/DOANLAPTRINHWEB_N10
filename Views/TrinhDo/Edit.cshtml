@model WebQLNhanSu.Models.TrinhDo

<h2>Sửa trình độ</h2>

<form asp-action="Edit">
    <input type="hidden" asp-for="MaTrinhDo" />
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="mb-3">
        <label asp-for="TenTrinhDo" class="form-label">Tên trình độ</label>
        <input asp-for="TenTrinhDo" class="form-control" />
        <span asp-validation-for="TenTrinhDo" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Lưu</button>
    <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
@model WebQLNhanSu.Models.ChucVu

@{
    ViewData["Title"] = "Chi tiết chức vụ";
}

<div class="crud-page">
    <div class="card card-modern p-4 p-md-5">
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4">
            <div>
                <h2 class="section-title mb-1">Chi tiết chức vụ</h2>
                <p class="section-subtitle mb-0">Xem thông tin chi tiết của chức vụ</p>
            </div>
            <span class="badge-soft mt-3 mt-md-0">Danh mục</span>
        </div>

        <div class="row g-4">
            <div class="col-md-4">
                <label class="form-label">Mã chức vụ</label>
                <div class="detail-box">@Model.MaChucVu</div>
            </div>

            <div class="col-md-4">
                <label class="form-label">Tên chức vụ</label>
                <div class="detail-box">@Model.TenChucVu</div>
            </div>

            <div class="col-md-4">
                <label class="form-label">Lương cơ bản</label>
                <div class="detail-box">@Model.LuongCoBan.ToString("N0")</div>
            </div>
        </div>

        <div class="page-actions">
            <a asp-action="Edit" asp-route-id="@Model.MaChucVu" class="btn btn-warning">Sửa</a>
            <a asp-action="Index" class="btn btn-outline-secondary">Quay lại</a>
        </div>
    </div>
</div>
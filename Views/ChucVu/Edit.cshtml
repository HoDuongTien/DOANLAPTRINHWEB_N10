@model WebQLNhanSu.Models.ChucVu

<h2>Sửa chức vụ</h2>

<form asp-action="Edit">
    <input type="hidden" asp-for="MaChucVu" />
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="mb-3">
        <label asp-for="TenChucVu" class="form-label">Tên chức vụ</label>
        <input asp-for="TenChucVu" class="form-control" />
        <span asp-validation-for="TenChucVu" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="LuongCoBan" class="form-label">Lương cơ bản</label>
        <input asp-for="LuongCoBan" type="number" step="0.01" class="form-control" />
        <span asp-validation-for="LuongCoBan" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Lưu</button>
    <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
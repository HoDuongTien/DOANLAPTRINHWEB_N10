@model WebQLNhanSu.Models.ChucVu

@{
    ViewData["Title"] = "Xóa chức vụ";
}

<div class="crud-page">
    <div class="card card-modern delete-card p-4 p-md-5">
        <div class="mb-4">
            <h2 class="section-title mb-1 text-danger">Xóa chức vụ</h2>
            <p class="section-subtitle mb-0">Xác nhận trước khi xóa dữ liệu</p>
        </div>

        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="warning-box mb-4">
            Bạn có chắc muốn xóa chức vụ này không?
        </div>

        <div class="row g-4">
            <div class="col-md-4">
                <label class="form-label">Mã chức vụ</label>
                <div class="detail-box">@Model.MaChucVu</div>
            </div>

            <div class="col-md-4">
                <label class="form-label">Tên chức vụ</label>
                <div class="detail-box">@Model.TenChucVu</div>
            </div>

            <div class="col-md-4">
                <label class="form-label">Lương cơ bản</label>
                <div class="detail-box">@Model.LuongCoBan.ToString("N0")</div>
            </div>
        </div>

        <form asp-action="Delete" method="post" class="page-actions">
            <input type="hidden" asp-for="MaChucVu" />
            <button type="submit" class="btn btn-danger">Xóa</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Quay lại</a>
        </form>
    </div>
</div>
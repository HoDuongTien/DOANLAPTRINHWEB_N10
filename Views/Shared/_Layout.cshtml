<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - WebQLNhanSu</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/WebQLNhanSu.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg app-navbar shadow-sm">
            <div class="container">
                <a class="navbar-brand fw-bold d-flex align-items-center gap-2" asp-controller="Home" asp-action="Index">
                    <span class="brand-logo"><i class="bi bi-people-fill"></i></span>
                    <span>WebQLNhanSu</span>
                </a>

                <button class="navbar-toggler text-white border-0" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar">
                    <span><i class="bi bi-list fs-2 text-white"></i></span>
                </button>

                <div class="collapse navbar-collapse" id="mainNavbar">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0 align-items-lg-center gap-lg-1">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">
                                <i class="bi bi-house-door me-1"></i>Trang chủ
                            </a>
                        </li>

                        @if (User.Identity != null && User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Profile" asp-action="Index">
                                    <i class="bi bi-person-circle me-1"></i>Hồ sơ
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link" asp-controller="ChamCong" asp-action="Index">
                                    <i class="bi bi-clock-history me-1"></i>Chấm công
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link" asp-controller="NghiPhep" asp-action="Index">
                                    <i class="bi bi-calendar-check me-1"></i>Nghỉ phép
                                </a>
                            </li>

                            @if (User.IsInRole("Admin") || User.IsInRole("HR"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Luong" asp-action="Manage">
                                        <i class="bi bi-cash-stack me-1"></i>Quản lý lương
                                    </a>
                                </li>
                            }
                            else
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Luong" asp-action="Index">
                                        <i class="bi bi-cash-stack me-1"></i>Lương của tôi
                                    </a>
                                </li>
                            }
                        }

                        @if (User.Identity != null && User.Identity.IsAuthenticated &&
                            (User.IsInRole("Admin") || User.IsInRole("HR")))
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                                    <i class="bi bi-folder2-open me-1"></i>Danh mục
                                </a>
                                <ul class="dropdown-menu shadow border-0 rounded-4 p-2">
                                    <li><a class="dropdown-item rounded-3" asp-controller="PhongBan" asp-action="Index">Phòng ban</a></li>
                                    <li><a class="dropdown-item rounded-3" asp-controller="ChucVu" asp-action="Index">Chức vụ</a></li>
                                    <li><a class="dropdown-item rounded-3" asp-controller="TrinhDo" asp-action="Index">Trình độ</a></li>
                                    <li><a class="dropdown-item rounded-3" asp-controller="LoaiHopDong" asp-action="Index">Loại hợp đồng</a></li>
                                    <li><a class="dropdown-item rounded-3" asp-controller="CaLamViec" asp-action="Index">Ca làm việc</a></li>
                                </ul>
                            </li>
                        }
                    </ul>

                    <div class="d-flex align-items-center">
                        <partial name="_LoginPartial" />
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <main class="page-wrapper">
        <div class="container py-4">
            @if (TempData["msg"] != null)
            {
                <div class="alert alert-success alert-modern shadow-sm border-0 rounded-4">
                    <i class="bi bi-check-circle-fill me-2"></i>@TempData["msg"]
                </div>
            }

            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-modern shadow-sm border-0 rounded-4">
                    <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
                </div>
            }

            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger shadow-sm border-0 rounded-4">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["Error"]
                </div>
            }

            @RenderBody()
        </div>
    </main>

    <footer class="app-footer mt-4">
        <div class="container d-flex flex-column flex-md-row justify-content-between align-items-center py-3">
            <div>
                &copy; 2026 - <strong>WebQLNhanSu</strong>
            </div>
            <div>
                <a asp-controller="Home" asp-action="Privacy" class="footer-link">Privacy</a>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
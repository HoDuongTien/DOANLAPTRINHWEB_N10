@model WebQLNhanSu.Models.LoaiHopDong

<h2>Thêm loại hợp đồng</h2>

<form asp-action="Create">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="mb-3">
        <label asp-for="TenLoaiHopDong" class="form-label">Tên loại hợp đồng</label>
        <input asp-for="TenLoaiHopDong" class="form-control" />
        <span asp-validation-for="TenLoaiHopDong" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Lưu</button>
    <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}